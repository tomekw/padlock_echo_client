with "padlock_echo_client_config.gpr";
with "padlock_echo_client_tests_deps.gpr";
with "padlock_echo_client.gpr";

project Padlock_Echo_Client_Tests is
   for Source_Dirs use ("tests");
   for Object_Dir use "target/" & Padlock_Echo_Client_Config.Build_Profile & "/obj-tests";
   for Exec_Dir use "target/" & Padlock_Echo_Client_Config.Build_Profile & "/bin";
   for Main use ("tests_main.adb");

   package Binder is
      for Default_Switches ("Ada") use Padlock_Echo_Client_Config.Binder_Switches;
   end Binder;

   package Builder is
      for Executable ("tests_main.adb") use "tests";
      for Default_Switches ("Ada") use Padlock_Echo_Client_Config.Builder_Switches;
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use Padlock_Echo_Client_Config.Compiler_Switches;
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use Padlock_Echo_Client_Config.Linker_Switches;
   end Linker;
end Padlock_Echo_Client_Tests;
